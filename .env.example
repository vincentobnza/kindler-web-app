# Open Library JSON API origin (search + work details). No key required.
VITE_API_BASE_URL=https://openlibrary.org

# Open Library cover-image CDN origin.
VITE_COVERS_BASE_URL=https://covers.openlibrary.org

# Public origin of the deployed site — used for canonical + Open Graph URLs.
VITE_SITE_URL=http://localhost:5173

# Feature flag example — toggle analytics wiring without a code change.
VITE_ENABLE_ANALYTICS=false
